{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "os:allow-platform",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "../Sidecar/src-bun/bun-sidecar",
          "sidecar": true
        },
        {
          "name": "../Sidecar/src-python/python-sidecar",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "../Sidecar/src-bun/bun-sidecar",
          "sidecar": true
        },
        {
          "name": "../Sidecar/src-python/python-sidecar",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-stdin-write",
      "allow": [
        {
          "name": "../Sidecar/src-bun/bun-sidecar",
          "sidecar": true
        },
        {
          "name": "../Sidecar/src-python/python-sidecar",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "../Sidecar/src-bun/bun-sidecar",
          "sidecar": true
        },
        {
          "name": "../Sidecar/src-python/python-sidecar",
          "sidecar": true
        }
      ]
    }
  ]
}
